#!/usr/bin/env python3
"""ROS node for publishing local WAV audio files as a real-time stream.
"""

from __future__ import annotations

import os
import sys
import time
import wave

# Resolve local paths so we can import from src/
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../src"))

from crispasr_ros.compat import RosNode, find_workspace_root
from crispasr_msgs.msg import AudioData

class AudioPublisherNode:
    """Simulates real-time streaming audio by reading a WAV file and publishing chunks."""

    def __init__(self) -> None:
        """Initialize the ROS node, parameters, and audio publishers."""
        self.node = RosNode("audio_publisher_node")
        
        self.wav_path = self.node.get_param("wav_path", "test_audio/sample.wav")
        self.loop = self.node.get_param("loop", True)
        self.chunk_duration = self.node.get_param("chunk_duration", 0.1) # 100ms chunks
        
        # Resolve relative wav_path from workspace root if it doesn't exist locally (due to CWD change in ROS1)
        if not os.path.isabs(self.wav_path) and not os.path.exists(self.wav_path):
            ws_root = find_workspace_root(os.path.dirname(__file__))
            if ws_root:
                resolved = os.path.join(ws_root, self.wav_path)
                if os.path.exists(resolved):
                    self.wav_path = resolved
        
        audio_topic = self.node.get_param("audio_topic", "/audio")
        self.pub = self.node.create_publisher(AudioData, audio_topic)

        self.node.log_info(f"Audio Publisher Node initialized. Reading: {self.wav_path}")

        
    def run(self) -> None:
        """Execute the audio streaming loop."""
        while not self.node.is_shutdown():
            if not os.path.exists(self.wav_path):
                self.node.log_error(f"Wav file not found: {self.wav_path}")
                time.sleep(2.0)
                continue
                
            try:
                wf = wave.open(self.wav_path, 'rb')
            except Exception as e:
                self.node.log_error(f"Failed to open wav file: {e}")
                time.sleep(2.0)
                continue
                
            channels = wf.getnchannels()
            sample_width = wf.getsampwidth()
            framerate = wf.getframerate()
            
            self.node.log_info(f"Opened WAV: {channels} channels, {sample_width} bytes/sample, {framerate} Hz")
            
            if framerate != 16000 or channels != 1 or sample_width != 2:
                self.node.log_warn("Audio is not 16kHz mono 16-bit PCM! Whisper expects 16kHz mono. Results may be poor.")
                
            # Calculate chunk size in frames
            chunk_size = int(framerate * self.chunk_duration)
            
            data = wf.readframes(chunk_size)
            while len(data) > 0 and not self.node.is_shutdown():
                msg = AudioData()
                msg.data = data
                self.pub.publish(msg)
                
                # Sleep to simulate real-time streaming
                time.sleep(self.chunk_duration)
                
                data = wf.readframes(chunk_size)
                
            wf.close()
            self.node.log_info("Finished audio file playback.")
            
            if not self.loop:
                break
                
            self.node.log_info("Looping audio file...")
            time.sleep(1.0) # Gap between loops

def main() -> None:
    node = AudioPublisherNode()
    node.run()

if __name__ == "__main__":
    main()

