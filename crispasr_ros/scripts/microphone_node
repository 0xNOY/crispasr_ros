#!/usr/bin/env python3
"""ROS node for capturing microphone audio using sounddevice and publishing PCM chunks."""

from __future__ import annotations

import os
import shlex
import subprocess
import sys
import time
from typing import Any

# Resolve local paths so we can import from src/
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../src"))


from crispasr_msgs.msg import AudioData
from crispasr_ros.audio_resample import candidate_capture_rates, resample_int16_mono
from crispasr_ros.compat import RosNode


class MicrophoneNode:
    """Captures microphone audio in real-time and publishes it to a ROS topic."""

    def __init__(self) -> None:
        """Initialize the ROS node, query devices, and prepare the audio stream."""
        self.node = RosNode("microphone_node")

        self.device_index = int(self.node.get_param("device_index", -1))
        self.chunk_duration = self.node.get_param("chunk_duration", 0.1)  # 100ms chunks
        self.sample_rate = int(self.node.get_param("sample_rate", 16000))
        self.capture_sample_rate = int(self.node.get_param("capture_sample_rate", 0))
        self.audio_backend = (
            str(self.node.get_param("audio_backend", "arecord")).strip().lower()
        )
        self.ssh_host = self.node.get_param("ssh_host", "")
        self.ssh_compression = self.node.get_param("ssh_compression", False)
        self.ssh_arecord_command = self.node.get_param(
            "ssh_arecord_command",
            "arecord -q -f S16_LE -r 16000 -c 1 -t raw -",
        )
        self.arecord_command = self.node.get_param(
            "arecord_command",
            "arecord -q -D default -f S16_LE -r 16000 -c 1 -t raw -",
        )

        self.audio_topic = self.node.get_param("audio_topic", "/audio")
        self.pub = self.node.create_publisher(AudioData, self.audio_topic)
        self.output_blocksize = int(self.sample_rate * self.chunk_duration)
        self.capture_rate = self.sample_rate
        self.blocksize = self.output_blocksize
        self.chunk_bytes = self.output_blocksize * 2
        self.subscriber_poll_interval = 0.1
        self.stream = None

        if self.ssh_host:
            self.node.log_info(
                f"Microphone node using SSH audio from {self.ssh_host}. "
                "Remote arecord outputs raw PCM."
            )
            return

        if self.audio_backend == "arecord":
            self.node.log_info(
                "Microphone node using local arecord audio. "
                "arecord outputs raw 16kHz mono 16-bit PCM."
            )
            return

        if self.audio_backend != "sounddevice":
            self.node.log_error(
                f"Unsupported audio_backend '{self.audio_backend}'. "
                "Use 'arecord' or 'sounddevice'."
            )
            sys.exit(1)

        import sounddevice as sd

        self.sd = sd

        # Log available devices to help users debug
        self._log_available_devices()

        # Select device
        device = None
        device_info = None

        try:
            if self.device_index == -1:
                default_device = self.sd.default.device[0]
                if default_device == -1 or default_device is None:
                    raise ValueError(
                        "No default audio input device is configured on this system."
                    )
                device = default_device
                device_info = self.sd.query_devices(device, "input")
            else:
                device = self.device_index
                device_info = self.sd.query_devices(device, "input")
        except Exception as e:
            self.node.log_error(f"Failed to resolve audio input device: {e}")
            self.node.log_error(
                "Please check if a microphone is connected and configured."
            )
            sys.exit(1)

        self.node.log_info(
            f"Using input device: {device_info['name']} (index: {device})"
        )

        self.stream = self._open_input_stream(device, device_info)

        self.node.log_info(
            f"Microphone stream opened at {self.capture_rate}Hz. "
            f"Publishing to {self.audio_topic} at {self.sample_rate}Hz mono 16-bit PCM."
        )

    def _log_available_devices(self) -> None:
        """Query and log all available input audio devices on the host."""
        try:
            devices = self.sd.query_devices()
            default_input = self.sd.default.device[0]
            self.node.log_info("--- Available Audio Input Devices ---")
            for idx, dev in enumerate(devices):
                if dev["max_input_channels"] > 0:
                    is_default = " [DEFAULT]" if idx == default_input else ""
                    self.node.log_info(
                        f"Index {idx}: {dev['name']} (Max Inputs: {dev['max_input_channels']}){is_default}"
                    )
            self.node.log_info("-------------------------------------")
        except Exception as e:
            self.node.log_warn(f"Could not query audio devices: {e}")

    def _open_input_stream(self, device: int, device_info: Any) -> Any:
        last_error = None
        for rate in candidate_capture_rates(
            self.sample_rate,
            self.capture_sample_rate,
            device_info.get("default_samplerate", 0),
        ):
            blocksize = max(1, int(rate * self.chunk_duration))
            try:
                self.sd.check_input_settings(
                    device=device,
                    channels=1,
                    samplerate=rate,
                    dtype="int16",
                )
                stream = self.sd.InputStream(
                    device=device,
                    channels=1,
                    samplerate=rate,
                    dtype="int16",
                    blocksize=blocksize,
                    callback=self.audio_callback,
                )
            except Exception as e:
                last_error = e
                self.node.log_warn(f"Audio input does not accept {rate}Hz: {e}")
                continue

            self.capture_rate = rate
            self.blocksize = blocksize
            if self.capture_rate != self.sample_rate:
                self.node.log_warn(
                    f"Capture device opened at {self.capture_rate}Hz; "
                    f"audio will be resampled to {self.sample_rate}Hz for ASR."
                )
            return stream

        self.node.log_error(f"Failed to open audio input stream: {last_error}")
        sys.exit(1)

    def audio_callback(
        self, indata: Any, frames: int, time_info: Any, status: Any
    ) -> None:
        """Callback function called by sounddevice for each new block of audio.

        Args:
            indata: Numpy array containing input audio samples.
            frames: Number of frames in the block.
            time_info: Dict containing timing information.
            status: Flag status representing overflow or underflow.
        """
        if status:
            self.node.log_warn(f"Audio stream status: {status}")

        # Convert int16 samples to target-rate raw bytes and publish.
        try:
            pcm = resample_int16_mono(indata, self.capture_rate, self.sample_rate)
            self._publish_audio(pcm.tobytes())
        except Exception as e:
            self.node.log_error(f"Failed to publish audio callback data: {e}")

    def _publish_audio(self, raw_bytes: bytes) -> None:
        msg = AudioData()
        msg.data = raw_bytes
        self.pub.publish(msg)

    def _has_audio_subscribers(self) -> bool:
        return self.pub.get_subscription_count() > 0

    def _wait_for_audio_subscriber(self) -> bool:
        logged_waiting = False
        while not self.node.is_shutdown():
            if self._has_audio_subscribers():
                return True
            if not logged_waiting:
                self.node.log_info(
                    f"Waiting for {self.audio_topic} subscribers before opening SSH audio stream."
                )
                logged_waiting = True
            time.sleep(self.subscriber_poll_interval)
        return False

    def _open_ssh_audio_process(self) -> subprocess.Popen:
        cmd = [
            "ssh",
            "-o",
            "StrictHostKeyChecking=no",
            "-o",
            "UserKnownHostsFile=/dev/null",
        ]
        if self.ssh_compression:
            cmd.append("-C")
        cmd.extend([self.ssh_host, self.ssh_arecord_command])
        self.node.log_info(f"Opening SSH audio stream from {self.ssh_host}")
        return subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            bufsize=0,
        )

    def _open_arecord_process(self) -> subprocess.Popen:
        cmd = shlex.split(self.arecord_command)
        self.node.log_info(
            f"Opening local arecord audio stream: {self.arecord_command}"
        )
        return subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            bufsize=0,
        )

    def _run_raw_pcm_stream(self, open_process: Any, stopped_message: str) -> None:
        while not self.node.is_shutdown():
            if not self._wait_for_audio_subscriber():
                break

            process = open_process()
            try:
                if process.stdout is None:
                    raise RuntimeError("Audio process stdout is unavailable")
                while not self.node.is_shutdown() and self._has_audio_subscribers():
                    data = process.stdout.read(self.chunk_bytes)
                    if not data:
                        break
                    self._publish_audio(data)
            finally:
                process.terminate()
                try:
                    process.wait(timeout=3)
                except subprocess.TimeoutExpired:
                    process.kill()
                self.node.log_info(stopped_message)

    def _run_ssh_stream(self) -> None:
        self._run_raw_pcm_stream(
            self._open_ssh_audio_process,
            "SSH microphone stream stopped.",
        )

    def _run_arecord_stream(self) -> None:
        self._run_raw_pcm_stream(
            self._open_arecord_process,
            "Local arecord microphone stream stopped.",
        )

    def run(self) -> None:
        """Start capturing audio and spin the ROS execution."""
        if self.ssh_host:
            try:
                self._run_ssh_stream()
            except Exception as e:
                self.node.log_error(f"Exception in SSH microphone streaming: {e}")
            return

        if self.audio_backend == "arecord":
            try:
                self._run_arecord_stream()
            except Exception as e:
                self.node.log_error(
                    f"Exception in local arecord microphone streaming: {e}"
                )
            return

        try:
            with self.stream:
                # Keep spinning ROS callbacks while stream is active
                while not self.node.is_shutdown():
                    time.sleep(0.1)
        except Exception as e:
            self.node.log_error(f"Exception in microphone node streaming: {e}")
        finally:
            self.node.log_info("Microphone node stream stopped.")


def main() -> None:
    node = MicrophoneNode()
    node.run()


if __name__ == "__main__":
    main()
