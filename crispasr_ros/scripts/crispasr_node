#!/usr/bin/env python3
"""ROS node for CrispASR speech recognition using Silero VAD."""

from __future__ import annotations

import os
import queue
import sys
import threading
import time
from typing import List, Optional

import numpy as np

# Resolve local paths so we can import from src/ and crispasr_src/python/
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../src"))

from crispasr_ros.runtime_paths import ensure_crispasr_runtime_paths

ensure_crispasr_runtime_paths(__file__)

from crispasr._binding import vad_slices
from crispasr_msgs.msg import AudioData, ConfirmationResult, SpeechResult
from crispasr_ros.asr_engine import ASREngine
from crispasr_ros.compat import RosNode, find_workspace_root
from crispasr_ros.confirmation import ConfirmationGate


def param_as_bool(value: object) -> bool:
    if isinstance(value, str):
        return value.strip().lower() in {"1", "true", "yes", "on"}
    return bool(value)


class CrispASRNode:
    """ROS ASR Node combining Silero VAD and Whisper-based GGML transcription."""

    def __init__(self) -> None:
        """Initialize the ROS node, parameters, and speech recognition engines."""
        self.node = RosNode("crispasr_node")

        # Load parameters
        model_path = self.node.get_param(
            "model_path", "models/cohere-transcribe-q4_k.gguf"
        )
        self.vad_model_path = self.node.get_param(
            "vad_model_path", "models/ggml-silero-v6.2.0.bin"
        )
        n_threads = self.node.get_param("n_threads", 4)
        frequency_penalty = float(self.node.get_param("frequency_penalty", 0.0))
        self.sample_rate = int(self.node.get_param("sample_rate", 16000))
        if self.sample_rate <= 0:
            self.node.log_error(f"sample_rate must be positive, got {self.sample_rate}")
            sys.exit(1)
        self.vad_threshold = self.node.get_param("vad_threshold", 0.5)
        self.silence_duration = self.node.get_param("silence_duration", 0.8)
        phrase_time_limit = float(self.node.get_param("phrase_time_limit", 0.0))
        self.phrase_time_limit = phrase_time_limit if phrase_time_limit > 0.0 else None
        self.enable_partial_results = param_as_bool(
            self.node.get_param("enable_partial_results", False)
        )
        max_audio_queue_chunks = int(self.node.get_param("max_audio_queue_chunks", 30))
        self.language = self.node.get_param(
            "language", ""
        )  # empty string means auto-detect
        audio_topic = self.node.get_param("audio_topic", "/audio")
        confirmation_result_topic = self.node.get_param(
            "confirmation_result_topic", "/confirmation_result"
        )
        confirmation_wake_words = self.node.get_param(
            "confirmation_wake_words",
            ["eraser", "hey eraser", "イレーサー"],
        )
        confirmation_positive_words = self.node.get_param(
            "confirmation_positive_words",
            [
                "yes",
                "yeah",
                "yep",
                "ok",
                "okay",
                "ready",
                "done",
                "release",
                "はい",
                "うん",
                "レディ",
                "リリース",
            ],
        )
        confirmation_negative_words = self.node.get_param(
            "confirmation_negative_words",
            ["no", "nope", "wrong", "incorrect", "not yet", "いいえ", "違う", "まだ"],
        )
        confirmation_wake_window_sec = self.node.get_param(
            "confirmation_wake_window_sec", 3.0
        )
        confirmation_require_wake_word = self.node.get_param(
            "confirmation_require_wake_word", True
        )

        ws_root = find_workspace_root(os.path.dirname(__file__))

        # Resolve ASR model path
        if not os.path.isabs(model_path) and not os.path.exists(model_path) and ws_root:
            resolved = os.path.join(ws_root, model_path)
            if os.path.exists(resolved):
                model_path = resolved

        # Resolve VAD model path
        if (
            not os.path.isabs(self.vad_model_path)
            and not os.path.exists(self.vad_model_path)
            and ws_root
        ):
            resolved = os.path.join(ws_root, self.vad_model_path)
            if os.path.exists(resolved):
                self.vad_model_path = resolved

        self.node.log_info(f"Initializing ASREngine with model: {model_path}")
        try:
            self.engine = ASREngine(
                model_path=model_path,
                n_threads=n_threads,
                frequency_penalty=frequency_penalty,
            )
        except Exception as e:
            self.node.log_error(f"Failed to initialize CrispASR Engine: {e}")
            sys.exit(1)

        if not os.path.exists(self.vad_model_path):
            self.node.log_error(f"VAD model not found: {self.vad_model_path}")
            sys.exit(1)
        self.node.log_info(f"Loaded Silero VAD model: {self.vad_model_path}")

        # Thread-safe Communication Queue
        self.audio_queue: queue.Queue[np.ndarray] = queue.Queue(
            maxsize=max(1, max_audio_queue_chunks)
        )
        self.last_rx_time = time.time()
        self.keep_running = True
        self.is_sleeping = False
        self.clear_requested = threading.Event()
        self.lock = threading.Lock()

        # Create Publisher and Subscriber using global topic names by default
        self.pub = self.node.create_publisher(SpeechResult, "/speech_result")
        self.confirmation_pub = self.node.create_publisher(
            ConfirmationResult, confirmation_result_topic
        )
        self.node.create_subscriber(AudioData, audio_topic, self.audio_callback)
        self.confirmation_gate = ConfirmationGate(
            wake_words=confirmation_wake_words,
            positive_words=confirmation_positive_words,
            negative_words=confirmation_negative_words,
            wake_window_sec=confirmation_wake_window_sec,
            require_wake_word=confirmation_require_wake_word,
        )

        # Create Services for sleep/wake_up
        self.node.create_trigger_service("sleep", self.sleep_callback)
        self.node.create_trigger_service("wake_up", self.wake_up_callback)
        self.node.create_trigger_service("clear_buffer", self.clear_buffer_callback)

        # Start Worker Thread for processing VAD and ASR
        self.worker_thread = threading.Thread(target=self._processing_loop, daemon=True)
        self.worker_thread.start()

        self.node.log_info(
            f"CrispASR Node initialized. Listening on topic: {audio_topic}"
        )

    def sleep_callback(self) -> tuple[bool, str]:
        """Handle sleep service request by offloading the model to CPU."""
        with self.lock:
            if self.is_sleeping:
                return True, "ASR engine is already sleeping."
            self.node.log_info("Received sleep request. Offloading model to CPU.")
            try:
                # Clear queue to discard any pending audio
                while not self.audio_queue.empty():
                    try:
                        self.audio_queue.get_nowait()
                    except queue.Empty:
                        break
                self.is_sleeping = True
                self.engine.offload_to_cpu()
                return True, "ASR engine successfully offloaded to CPU."
            except Exception as e:
                err_msg = f"Failed to sleep ASR engine: {e}"
                self.node.log_error(err_msg)
                return False, err_msg

    def clear_buffer_callback(self) -> tuple[bool, str]:
        """Discard queued audio and ask the worker to reset its active phrase."""
        self._drain_audio_queue()
        self.clear_requested.set()
        self.last_rx_time = time.time()
        return True, "ASR audio queue and active phrase buffer clear requested."

    def wake_up_callback(self) -> tuple[bool, str]:
        """Handle wake_up service request by loading the model back to GPU."""
        with self.lock:
            if not self.is_sleeping:
                return True, "ASR engine is already awake."
            self.node.log_info("Received wake_up request. Loading model to GPU.")
            try:
                self.engine.load_to_gpu()
                self.is_sleeping = False
                return True, "ASR engine successfully loaded to GPU."
            except Exception as e:
                err_msg = f"Failed to wake up ASR engine: {e}"
                self.node.log_error(err_msg)
                return False, err_msg

    def audio_callback(self, msg: AudioData) -> None:
        """Handle incoming AudioData messages by pushing them immediately to a queue.

        Args:
            msg: Custom message containing raw uint8 bytes representing 16-bit PCM.
        """
        if self.is_sleeping or not self._has_result_consumers():
            return

        if not msg.data:
            return

        # Basic validation: PCM 16-bit mono means 2 bytes per sample.
        # Length of data must be an even number.
        if len(msg.data) % 2 != 0:
            self.node.log_warn(
                "Received audio message with odd byte length. Discarding corrupt data."
            )
            return

        # Convert uint8[] bytes to int16 PCM, then normalize to float32
        try:
            int16_samples = np.frombuffer(msg.data, dtype=np.int16)
            float32_samples = int16_samples.astype(np.float32) / 32768.0
        except Exception as e:
            self.node.log_error(f"Failed to decode audio data: {e}")
            return

        # Enqueue immediately (non-blocking)
        self.last_rx_time = time.time()
        try:
            self.audio_queue.put_nowait(float32_samples)
        except queue.Full:
            try:
                self.audio_queue.get_nowait()
            except queue.Empty:
                pass
            try:
                self.audio_queue.put_nowait(float32_samples)
            except queue.Full:
                self.node.log_warn("Audio queue is full. Dropping newest audio chunk.")

    def _has_speech_result_subscribers(self) -> bool:
        return self.pub.get_subscription_count() > 0

    def _has_result_consumers(self) -> bool:
        return (
            self._has_speech_result_subscribers()
            or self.confirmation_pub.get_subscription_count() > 0
        )

    def _drain_audio_queue(self) -> None:
        while True:
            try:
                self.audio_queue.get_nowait()
            except queue.Empty:
                return

    def _processing_loop(self) -> None:
        """Worker loop that handles VAD computation, timeouts, and ASR inference."""
        audio_buffer: List[float] = []
        last_partial_text = ""
        last_inference_time = time.time()
        in_speech = False
        phrase_start_sec: Optional[float] = None

        transcribe_interval = 0.6  # Partial transcription interval (seconds)
        silence_timeout = 1.5  # Watchdog timeout (seconds)
        min_vad_samples = int(0.5 * self.sample_rate)

        lang_code = self.language.strip() if self.language.strip() else None

        while self.keep_running and not self.node.is_shutdown():
            if self.clear_requested.is_set():
                self.clear_requested.clear()
                self._drain_audio_queue()
                audio_buffer = []
                in_speech = False
                phrase_start_sec = None
                last_partial_text = ""
                last_inference_time = time.time()
                self.node.log_info("Cleared ASR audio buffer.")
                continue

            if self.is_sleeping:
                if audio_buffer:
                    audio_buffer = []
                in_speech = False
                phrase_start_sec = None
                last_partial_text = ""
                time.sleep(0.05)
                continue

            if not self._has_result_consumers():
                if audio_buffer:
                    audio_buffer = []
                self._drain_audio_queue()
                in_speech = False
                phrase_start_sec = None
                last_partial_text = ""
                time.sleep(0.05)
                continue

            try:
                # Retrieve audio from queue with timeout to allow periodic watchdog checks
                float32_samples = self.audio_queue.get(timeout=0.05)
                audio_buffer.extend(float32_samples)
            except queue.Empty:
                pass

            now = time.time()
            total_duration = len(audio_buffer) / float(self.sample_rate)

            # 1. Silence watchdog timeout check
            if now - self.last_rx_time > silence_timeout and len(audio_buffer) > 0:
                self.node.log_info("Silence watchdog timeout. Flushing entire buffer.")
                audio_buffer, in_speech, last_partial_text = self._flush_buffer(
                    audio_buffer, lang_code, cut_time_sec=None
                )
                phrase_start_sec = None
                self.last_rx_time = now
                continue

            # 2. VAD processing if buffer has enough samples (>= 0.5s)
            if len(audio_buffer) >= min_vad_samples:
                pcm_array = np.array(audio_buffer, dtype=np.float32)
                spans = []
                try:
                    spans = vad_slices(
                        pcm_array,
                        self.vad_model_path,
                        sample_rate=self.sample_rate,
                        threshold=self.vad_threshold,
                        n_threads=1,
                    )
                except Exception as e:
                    self.node.log_error(f"VAD slices failed: {e}")
                    # On error, clear buffer to prevent overflow
                    audio_buffer = []
                    in_speech = False
                    continue

                if len(spans) > 0:
                    in_speech = True
                    if phrase_start_sec is None:
                        phrase_start_sec = spans[0].start
                    last_span = spans[-1]
                    last_end = last_span.end

                    if (
                        self.phrase_time_limit is not None
                        and total_duration - phrase_start_sec >= self.phrase_time_limit
                    ):
                        cut_time_sec = phrase_start_sec + self.phrase_time_limit
                        self.node.log_info(
                            f"Phrase time limit reached ({self.phrase_time_limit:.2f}s). Flushing buffer."
                        )
                        audio_buffer, in_speech, last_partial_text = self._flush_buffer(
                            audio_buffer, lang_code, cut_time_sec=cut_time_sec
                        )
                        phrase_start_sec = None
                        self.last_rx_time = now
                        continue

                    # If silence duration after the last detected speech span exceeds threshold, flush
                    if total_duration - last_end >= self.silence_duration:
                        self.node.log_info(
                            f"VAD detected speech end (silence gap: {total_duration - last_end:.2f}s). Flushing buffer."
                        )
                        audio_buffer, in_speech, last_partial_text = self._flush_buffer(
                            audio_buffer, lang_code, cut_time_sec=last_end
                        )
                        phrase_start_sec = None
                        self.last_rx_time = now
                else:
                    # No speech segments detected.
                    # Clear accumulated silence if it exceeds 2.0s to avoid memory inflation.
                    if not in_speech and total_duration >= 2.0:
                        audio_buffer = []
                        phrase_start_sec = None

            # 3. Periodic partial transcription during active speech
            if (
                in_speech
                and self.enable_partial_results
                and len(audio_buffer) >= min_vad_samples
                and self._has_speech_result_subscribers()
            ):
                if now - last_inference_time > transcribe_interval:
                    pcm_array = np.array(audio_buffer, dtype=np.float32)
                    text = self.engine.transcribe(pcm_array, language=lang_code)
                    if self.clear_requested.is_set():
                        continue
                    if text and text != last_partial_text:
                        self._publish_result(text, is_final=False)
                        last_partial_text = text
                    last_inference_time = now

    def _flush_buffer(
        self,
        audio_buffer: List[float],
        language: Optional[str],
        cut_time_sec: Optional[float] = None,
    ) -> tuple[List[float], bool, str]:
        """Transcribe accumulated buffer, publish final result, and return reset states.

        Args:
            audio_buffer: Audio sample buffer to transcribe.
            language: Optional language ISO code.
            cut_time_sec: Optional duration indicating where to split the buffer.

        Returns:
            A tuple of (remaining_audio_buffer, in_speech_state, last_partial_text_reset).
        """
        pcm_array = np.array(audio_buffer, dtype=np.float32)

        if cut_time_sec is not None:
            cut_idx = int(cut_time_sec * self.sample_rate)
            transcribe_pcm = pcm_array[:cut_idx]
            remaining_buffer = list(pcm_array[cut_idx:])
        else:
            transcribe_pcm = pcm_array
            remaining_buffer = []

        text = self.engine.transcribe(transcribe_pcm, language=language)
        if self.clear_requested.is_set():
            return [], False, ""
        if text:
            self._publish_result(text, is_final=True)

        return remaining_buffer, False, ""

    def _publish_result(self, text: str, is_final: bool) -> None:
        """Publish the ASR transcription result.

        Args:
            text: Transcribed text string.
            is_final: True if speech chunk ended, False for incremental updates.
        """
        result_msg = SpeechResult()
        result_msg.text = text
        result_msg.start = 0.0
        result_msg.end = 0.0
        result_msg.is_final = is_final
        self.pub.publish(result_msg)

        status = "FINAL" if is_final else "PARTIAL"
        self.node.log_info(f"[{status}] {text}")

        if is_final:
            self._publish_confirmation_result(text)

    def _publish_confirmation_result(self, text: str) -> None:
        decision = self.confirmation_gate.consume(text)
        if decision is None:
            return

        msg = ConfirmationResult()
        msg.text = decision.text
        msg.intent = decision.intent
        msg.command = decision.command
        msg.has_wake_word = decision.has_wake_word
        msg.is_within_wake_window = decision.is_within_wake_window
        self.confirmation_pub.publish(msg)
        self.node.log_info(
            f"[CONFIRMATION] intent={msg.intent} command={msg.command} text={msg.text}"
        )

    def run(self) -> None:
        """Start spinning the node execution."""
        self.node.spin()
        self.keep_running = False
        try:
            self.worker_thread.join(timeout=1.0)
        except Exception:
            pass


def main() -> None:
    node = CrispASRNode()
    node.run()


if __name__ == "__main__":
    main()
